#!/usr/bin/env bash

# Check if the bucket name was provided
if [ -z "$1" ]; then
    echo "Error: No bucket name provided."
    echo "Usage: ./list-objects <bucket-name>"
    exit 1
fi

BUCKET_NAME=$1

echo "Listing objects in bucket: $BUCKET_NAME..."

# Run the list command
aws s3api list-objects-v2 \
    --bucket "$BUCKET_NAME" \
    --query 'Contents[].{Key: Key, Size: Size}' \
    --output table

# Check result
if [ $? -ne 0 ]; then
    echo "Error: Failed to list objects (Does the bucket exist?)."
fi
