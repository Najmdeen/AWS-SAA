# Local .terraform directories
**/.terraform/*

# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files, which are likely to contain sensitive data, such as
# password, private keys, and other secrets. These should not be part of version 
# control as they are data-and-architecture specific.
*.tfvars
*.tfvars.json

# Ignore override files as they are usually used to override resources locally and so
# are not checked in
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Include override mirror directories
example_override.tf

# Include terraform plan outputs
*.tfplan

# .terraform.lock.hcl is usually included in Git to ensure consistent provider versions.
# If you want to exclude it, uncomment the line below:
# .terraform.lock.hcl
